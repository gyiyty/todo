# BT Panel includes site files inside the global http block. Keep these zones
# outside the server block and do not duplicate their names in another site.
limit_req_zone $binary_remote_addr zone=todo_login:1m rate=5r/m;
limit_conn_zone $binary_remote_addr zone=todo_connections:1m;

server {
    listen 38675 ssl default_server;
    http2 on;
    server_name 120.79.29.34;

    ssl_certificate /www/server/panel/vhost/cert/todo-ip/server.cert.pem;
    ssl_certificate_key /www/server/panel/vhost/cert/todo-ip/server.key.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:TODO_SSL:1m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    server_tokens off;
    client_max_body_size 2m;
    client_body_timeout 15s;
    keepalive_timeout 30s;
    limit_conn todo_connections 20;
    limit_req_status 429;

    access_log /www/wwwlogs/todo-ip.log;
    error_log /www/wwwlogs/todo-ip.error.log warn;

    # Do not let arbitrary DNS names reuse this IP-based virtual host.
    if ($host != "120.79.29.34") {
        return 444;
    }

    location = /api/v1/session {
        limit_req zone=todo_login burst=3 nodelay;

        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Host $http_host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 38675;
        proxy_set_header Connection "";
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }

    location / {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Host $http_host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 38675;
        proxy_set_header Connection "";
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }
}
